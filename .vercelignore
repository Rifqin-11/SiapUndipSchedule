# Vercel ignore file
# Files and directories to ignore during deployment

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
.next/
out/
dist/

# Debug
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Testing
coverage/
.nyc_output/

# Misc
.eslintcache
